#!/usr/bin/env bash
# kei ‚ÄĒ KeiSeiKit launcher with TUI splash, then exec claude.
#
# Distinct from `keisei` (Rust exobrain CLI: `keisei attach/mount/...`).
# `kei` is the lightweight splash + launch entry point most users want.
#
# Usage:
#   kei                     # splash ‚Üí claude (interactive REPL)
#   kei --no-splash         # skip splash ‚Üí exec claude
#   kei --status            # status only, don't launch claude
#   kei message ...         # inter-session mailbox (send/inbox/list) ‚ÄĒ see kei-message.sh
#   kei configure           # re-pick stack profile + opt-in hook packs
#   kei pick                # interactive picker ‚Üí set primary ‚Üí launch it
#   kei agent <name> "<task>"        # invoke agent, backend from DNA ‚Üí primary
#   kei agent --on=<backend> <name> "<task>"   # override backend
#   kei run-via <backend> <name> "<task>"      # invoke agent on explicit backend
#                           # backends: claude grok agy copilot kimi codex
#                           # `kei run-via list` shows install status + agents
#   kei primary [<backend>] # get/set primary LLM provider (DNA fallback)
#   kei mcp-wire [<cli>]    # wire kei-mcp into a CLI's MCP config + hook setup
#                           # (Phase C cross-CLI policy enforcement)
#   kei mcp-wire --list     # show enforcement tier per CLI
#   kei limits              # probe each CLI's subscription quota (best-effort)
#                           # (4 of 5 CLIs have no public API ‚ÄĒ honest report)
#   kei onboard             # post-install wizard (pick primary + mcp-wire + check)
#   kei --on=<backend>      # one-shot launch of <backend> (does not change primary)
#   kei [args...]           # splash ‚Üí exec primary CLI (default: claude)
#
# The splash shows: substrate version, agent count, last sleep run,
# active sessions (kei-ping). Press any key to skip the dwell.
#
# Returns: same exit code as `claude`.

set -e

# --- subcommand dispatch (before splash) ---------------------------------
# `kei message ...`  ‚Üí mailbox CLI
# `kei configure`    ‚Üí hook/stack re-picker
# `kei agent ...`    ‚Üí DNA-resolved agent (manifest provider ‚Üí primary ‚Üí claude)
# `kei run-via ...`  ‚Üí explicit-backend agent invocation
# `kei primary ...`  ‚Üí get/set primary LLM provider
# rest = splash + launch claude (legacy primary).
case "${1:-}" in
  message|msg|m)
    shift
    exec "$HOME/.claude/scripts/kei-message.sh" "$@"
    ;;
  configure|config|reconfigure)
    shift
    exec "$HOME/.claude/scripts/kei-configure.sh" "$@"
    ;;
  agent)
    shift
    exec "$HOME/.claude/scripts/kei-agent-cli.sh" "$@"
    ;;
  run-via|via|agent-via)
    shift
    exec "$HOME/.claude/scripts/kei-agent-cli.sh" "$@"
    ;;
  second-opinion|2nd|so)
    shift
    exec "$HOME/.claude/scripts/kei-second-opinion.sh" "$@"
    ;;
  primary)
    shift
    exec "$HOME/.claude/scripts/kei-agent-cli.sh" primary "$@"
    ;;
  pick)
    shift
    exec "$HOME/.claude/scripts/kei-pick.sh" "$@"
    ;;
  mcp-wire|wire)
    shift
    exec "$HOME/.claude/scripts/kei-mcp-wire.sh" "$@"
    ;;
  limits|quota|usage)
    shift
    exec "$HOME/.claude/scripts/kei-limits.sh" "$@"
    ;;
  glm-ledger|glm-report|glm)
    shift
    exec "$HOME/.claude/scripts/kei-glm-ledger.sh" "$@"
    ;;
  glm-quota|glm-limit|glm-status)
    shift
    exec "$HOME/.claude/scripts/kei-glm-quota.sh" "$@"
    ;;
  onboard|setup|wizard)
    shift
    exec "$HOME/.claude/scripts/kei-onboard.sh" "$@"
    ;;
  status|health)
    # `kei status` ‚ÄĒ show splash + health summary, then exit (no claude).
    # Equivalent to `kei --status`. Previously this verb fell through to
    # the wrapper and silently launched claude ‚ÄĒ confusing for `kei status`
    # CI checks or shell aliases.
    shift
    set -- --status "$@"
    ;;
esac

# --- one-shot --on=<backend> override (does not write primary.toml) -------
ONESHOT_BACKEND=""
for arg in "$@"; do
  case "$arg" in
    --on=*) ONESHOT_BACKEND="${arg#--on=}" ;;
  esac
done

# --- args ----------------------------------------------------------------
SPLASH=1
STATUS_ONLY=0
PASSTHROUGH=()
for arg in "$@"; do
  case "$arg" in
    --on=*)      ;;  # already captured in ONESHOT_BACKEND; don't forward
    --no-splash) SPLASH=0 ;;
    --status)    STATUS_ONLY=1; SPLASH=1 ;;
    *)           PASSTHROUGH+=("$arg") ;;
  esac
done

# --- resolve primary backend ---------------------------------------------
# Order: --on=<backend> override ‚Üí ~/.claude/config/primary.toml ‚Üí claude.
resolve_primary() {
  if [ -n "$ONESHOT_BACKEND" ]; then printf '%s\n' "$ONESHOT_BACKEND"; return; fi
  if [ -n "${KEI_PRIMARY:-}" ]; then printf '%s\n' "$KEI_PRIMARY"; return; fi
  local cfg="$HOME/.claude/config/primary.toml"
  if [ -f "$cfg" ]; then
    awk -F'=' '/^provider[[:space:]]*=/ {
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", $2)
      gsub(/^"|"$/, "", $2)
      print $2; exit
    }' "$cfg"
    return
  fi
  printf 'claude\n'
}

# Map backend name ‚Üí executable. Mirrors scripts/kei-agent-cli.sh::backend_bin.
backend_bin_for() {
  case "$1" in
    claude)               echo "claude"  ;;
    grok)                 echo "grok"    ;;
    agy|antigravity)      echo "agy"     ;;
    copilot)              echo "copilot" ;;
    kimi)                 echo "kimi"    ;;
    codex)                echo "codex"   ;;
    glm)                  echo "claude"  ;;  # GLM rides the claude binary (Z.ai Anthropic-compat)
    *) return 1 ;;
  esac
}

PRIMARY="$(resolve_primary)"
PRIMARY_CLI="$(backend_bin_for "$PRIMARY")" || {
  echo "error: unknown primary backend: $PRIMARY" >&2
  exit 2
}
PRIMARY_BIN="$(command -v "$PRIMARY_CLI" 2>/dev/null || true)"

if [ -z "$PRIMARY_BIN" ] && [ "$STATUS_ONLY" = "0" ]; then
  echo "error: primary backend '$PRIMARY' ‚Üí '$PRIMARY_CLI' not on PATH." >&2
  case "$PRIMARY" in
    claude)  echo "  install: curl -fsSL https://claude.ai/install.sh | sh" >&2 ;;
    grok)    echo "  install: see https://x.ai/grok" >&2 ;;
    copilot) echo "  install: npm i -g @github/copilot" >&2 ;;
    kimi)    echo "  install: uv tool install kimi-cli" >&2 ;;
    agy)     echo "  install: see https://antigravity.dev" >&2 ;;
    codex)   echo "  install: see https://github.com/openai/codex" >&2 ;;
  esac
  echo "  or: kei pick   (interactive picker to choose + set primary)" >&2
  echo "  or: kei primary <backend>   (set a different default)" >&2
  exit 127
fi

# Legacy var name for splash code below.
CLAUDE_BIN="$PRIMARY_BIN"

# --- read state ----------------------------------------------------------
AGENTS_DIR="${HOME}/.claude/agents"
SYNC_DIR="${HOME}/.claude/memory/sync-repo"

# Agent count from generated .md files
agent_count() {
  local n=0
  if [ -d "$AGENTS_DIR" ]; then
    n=$(find "$AGENTS_DIR" -maxdepth 1 -name "*.md" -not -name "_*" 2>/dev/null | wc -l | tr -d ' ')
  fi
  printf '%s' "$n"
}

# Substrate version ‚ÄĒ read from installed plugin.json (or fallback).
# Single SSoT: plugin.json. Don't hardcode in splash again.
substrate_version() {
  local pj
  for pj in "$HOME/.claude/plugin.json" "$HOME/.local/share/keisei/plugin.json"; do
    if [ -f "$pj" ]; then
      sed -n 's/.*"version": *"\([^"]*\)".*/\1/p' "$pj" | head -1
      return
    fi
  done
  echo "unknown"
}

# Profile from .installed marker file
profile_name() {
  # install.sh stamps the chosen profile here; .installed only holds primitive
  # names (so the old `grep ^profile .installed` always returned "?").
  local f="$HOME/.claude/.kei-profile"
  if [ -f "$f" ]; then head -1 "$f"; else echo "?"; fi
}

# Last sleep run ‚ÄĒ checks BOTH pipelines and reports whichever is newer:
#   - remote/hybrid Phase B: ${SYNC_DIR}/reports/last-run.txt (epoch, written
#     by kei-sleep-sync.sh)
#   - local-only cron: newest dated report in ~/sleep-reports/, written by
#     nightly-sleep.sh (sleep-report-*.md) / weekly-deep-sleep.sh
#     (deep-sleep-plan-*.md) ‚ÄĒ these scripts use dated filenames instead of
#     a stable marker file, so we take the most recently modified match.
# Previously this only checked the remote path, so local-only installs
# (no KEI_MEMORY_REPO_* configured) showed a permanent "never" even with a
# genuinely scheduled and eventually-firing cron.
last_sleep_run() {
  local remote_f="${SYNC_DIR}/reports/last-run.txt" remote_ts="" local_dir="${HOME}/sleep-reports" local_ts="" newest

  if [ -f "$remote_f" ]; then
    remote_ts=$(cat "$remote_f" 2>/dev/null | head -1)
  fi

  if [ -d "$local_dir" ]; then
    newest=$(ls -t "$local_dir"/sleep-report-*.md "$local_dir"/deep-sleep-plan-*.md 2>/dev/null | head -1)
    if [ -n "$newest" ]; then
      # mtime ‚Üí epoch; GNU stat (Linux) vs BSD/macOS stat differ
      local_ts=$(stat -c %Y "$newest" 2>/dev/null || stat -f %m "$newest" 2>/dev/null)
    fi
  fi

  local ts=""
  if [ -n "$remote_ts" ] && [ -n "$local_ts" ]; then
    if [ "$remote_ts" -ge "$local_ts" ] 2>/dev/null; then ts="$remote_ts"; else ts="$local_ts"; fi
  elif [ -n "$remote_ts" ]; then
    ts="$remote_ts"
  elif [ -n "$local_ts" ]; then
    ts="$local_ts"
  fi

  if [ -n "$ts" ]; then
    # epoch ‚Üí human; macOS date(1) -r and Linux date(1) -d differ
    if date -r "$ts" '+%Y-%m-%d %H:%M' >/dev/null 2>&1; then
      date -r "$ts" '+%Y-%m-%d %H:%M'
    elif date -d "@$ts" '+%Y-%m-%d %H:%M' >/dev/null 2>&1; then
      date -d "@$ts" '+%Y-%m-%d %H:%M'
    else
      echo "$ts"
    fi
    return
  fi

  if crontab -l 2>/dev/null | grep -qE "nightly-sleep\.sh|weekly-deep-sleep\.sh"; then
    echo "never (local cron configured, awaiting first run)"
  else
    echo "never"
  fi
}

# Active session count via kei-ping (auto-selects redis or sqlite backend)
active_sessions() {
  if command -v kei-ping >/dev/null 2>&1; then
    kei-ping list 2>/dev/null | grep -cE '^\s*[0-9]+s\s' || echo "0"
  else
    echo "n/a"
  fi
}

# --- splash --------------------------------------------------------------
splash() {
  local p ac sl as
  p="$(profile_name)"
  ac="$(agent_count)"
  sl="$(last_sleep_run)"
  as="$(active_sessions)"

  # Only color if stdout is a tty. Brand palette: –≥–ĺ–Ľ—É–Ī–ĺ–Ļ (sky-blue) + –∂—Ď–Ľ—ā—č–Ļ (gold).
  local C0= C1= C2= C3= CV= CS= GO_BACK= SHADOW_BLOCK=
  if [ -t 1 ]; then
    C0=$'\033[0m'
    C1=$'\033[1;38;5;39m'    # –≥–ĺ–Ľ—É–Ī–ĺ–Ļ (sky-blue) ‚ÄĒ logo
    C2=$'\033[1;38;5;220m'   # –∂—Ď–Ľ—ā—č–Ļ (gold) ‚ÄĒ brand line
    C3=$'\033[2;38;5;39m'    # dim blue ‚ÄĒ separators
    CV=$'\033[1;38;5;220m'   # –∂—Ď–Ľ—ā—č–Ļ ‚ÄĒ field values
    CS=$'\033[1;38;5;130m'   # –Ī–Ľ–į–≥–ĺ—Ä–ĺ–ī–Ĺ–į—Ź –Ĺ–į—Ā—č—Č–Ķ–Ĺ–Ĺ–į—Ź –∂—Ď–Ľ—ā–ĺ-–Ī—Ä–ĺ–Ĺ–∑–ĺ–≤–į—Ź —ā–Ķ–Ĺ—Ć
    # v0.47 drop shadow: print shadow first (offset +2 cols right),
    # then \e[7A returns cursor to start of art, blue letters overwrite
    # shadow where they overlap. Visible shadow = right-edge tail +
    # one full row below blue's bottom (offset +1 row down).
    GO_BACK=$'\033[7A'
    SHADOW_BLOCK="
${CS}      ‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēó${C0}
${CS}      ‚Ėą‚Ėą‚ēĎ ‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĎ${C0}
${CS}      ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēĎ${C0}
${CS}      ‚Ėą‚Ėą‚ēĒ‚ēź‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ  ‚Ėą‚Ėą‚ēĎ‚ēö‚ēź‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ  ‚Ėą‚Ėą‚ēĎ${C0}
${CS}      ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ${C0}
${CS}      ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēĚ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēĚ${C0}${GO_BACK}"
  fi

  cat <<EOF
${SHADOW_BLOCK}
${C1}    ‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēó${C0}
${C1}    ‚Ėą‚Ėą‚ēĎ ‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĎ${C0}
${C1}    ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēĎ${C0}
${C1}    ‚Ėą‚Ėą‚ēĒ‚ēź‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ  ‚Ėą‚Ėą‚ēĎ‚ēö‚ēź‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ  ‚Ėą‚Ėą‚ēĎ${C0}
${C1}    ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ${C0}
${C1}    ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēĚ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēĚ${C0}

${C2}    KeiSeiKit ¬∑ substrate v$(substrate_version)${C0}
${C3}    ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ${C0}
      primary CLI    : ${CV}${PRIMARY}${C0}
      profile        : ${CV}${p}${C0}
      agents         : ${CV}${ac}${C0}
      last sleep run : ${CV}${sl}${C0}
      active sessions: ${CV}${as}${C0}
${C3}    ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ${C0}

EOF
}

# --- main ----------------------------------------------------------------
if [ "$SPLASH" = "1" ]; then
  splash
fi

if [ "$STATUS_ONLY" = "1" ]; then
  exit 0
fi

# Brief dwell so user sees splash before claude takes over the screen.
# Skipped if stdin not a tty (CI / piped) or if --no-splash.
if [ "$SPLASH" = "1" ] && [ -t 0 ] && [ -t 1 ]; then
  # Wait up to 0.6s; any keypress aborts immediately.
  read -t 0.6 -n 1 -s _ 2>/dev/null || true
fi

# GLM (Z.ai) primary: same claude binary, Anthropic-compatible endpoint.
# Source key from secrets (RULE 0.8) and inject env scoped to this exec only.
if [ "$PRIMARY" = "glm" ]; then
  KEI_SECRETS_FILE="${KEI_SECRETS_FILE:-$HOME/.claude/secrets/.env}"
  [ -f "$KEI_SECRETS_FILE" ] && { set -a; . "$KEI_SECRETS_FILE"; set +a; }
  if [ -z "${ZAI_API_KEY:-}" ]; then
    echo "error: primary 'glm' needs ZAI_API_KEY in $KEI_SECRETS_FILE" >&2
    exit 3
  fi
  exec env \
    ANTHROPIC_BASE_URL="${ZAI_BASE_URL:-https://api.z.ai/api/anthropic}" \
    ANTHROPIC_AUTH_TOKEN="$ZAI_API_KEY" \
    ANTHROPIC_DEFAULT_OPUS_MODEL="${ZAI_MODEL:-glm-5.2}" \
    ANTHROPIC_DEFAULT_SONNET_MODEL="${ZAI_MODEL:-glm-5.2}" \
    ANTHROPIC_DEFAULT_HAIKU_MODEL="${ZAI_SMALL_MODEL:-glm-5-turbo}" \
    "$CLAUDE_BIN" "${PASSTHROUGH[@]}"
fi

exec "$CLAUDE_BIN" "${PASSTHROUGH[@]}"
